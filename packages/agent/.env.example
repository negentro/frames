# Provider (required): claude | ollama
MODEL_PROVIDER=ollama

# Model config
EIGEN_MAX_BUDGET_PER_QUERY_USD=1.00   # Max spend per query (claude only)
EIGEN_MAX_TURNS=30                     # Max agent turns per query
EIGEN_MODEL=qwen2.5:32b               # Model name (claude-sonnet-4-6, qwen2.5:32b, etc.)

# Ollama settings (only when MODEL_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434 # Ollama server URL
OLLAMA_VISION_MODEL=qwen2.5vl          # Vision model for image description

# Server
PORT=8787
PROJECTS_DIR=/tmp/eigen-projects
