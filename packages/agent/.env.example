# Model config
EIGEN_MAX_TURNS=15                     # Max agent turns per query
EIGEN_MODEL=qwen2.5-coder:32b         # Coding model

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434 # Ollama server URL
OLLAMA_VISION_MODEL=qwen2.5vl         # Vision model for image description

# Server
PORT=8787
PROJECTS_DIR=/tmp/eigen-projects
API_URL=http://localhost:8788          # API server URL for R2 uploads
EIGEN_INTERNAL_API_KEY=eigen-local-dev-key # Shared secret for agent→API auth
